# ============================================================
# EduTrack — Configuración de Despliegue
# ⚠️  NO subir este archivo al repositorio (ver .gitignore)
# ============================================================

# ── API / Backend ────────────────────────────────────────────
API_BASE_URL=http://localhost:8080
API_VERSION=v1

# ── Autenticación JWT ────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_por_uno_seguro
JWT_EXPIRATION_MS=86400000

# ── Entorno de ejecución ─────────────────────────────────────
# Valores posibles: development | staging | production
APP_ENV=development

# ── Frontend Web (Wasm/JS) ───────────────────────────────────
WEB_HOST=localhost
WEB_PORT=8081

# ── Base de datos (si aplica backend local) ──────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edutrack_db
DB_USER=edutrack_user
DB_PASSWORD=cambia_esta_contrasena

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8081

# ── Logging ──────────────────────────────────────────────────
# Niveles: TRACE | DEBUG | INFO | WARN | ERROR
LOG_LEVEL=DEBUG

